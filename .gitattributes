# Auto-detect text files and normalize line endings to LF on commit
* text=auto eol=lf

# Source code
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.sh        text eol=lf

# Windows-specific scripts should keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf

# Binary files — do not modify line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.pdf       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.zip       binary
*.tar.gz    binary
*.dmg       binary
*.exe       binary
*.node      binary
